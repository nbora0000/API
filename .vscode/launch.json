{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Order API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-order",
            "program": "${workspaceFolder}/OrderApi/bin/Debug/net8.0/OrderApi.dll",
            "args": [],
            "cwd": "${workspaceFolder}/OrderApi",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/swagger"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": "Payment API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-payment",
            "program": "${workspaceFolder}/PaymentApi/bin/Debug/net8.0/PaymentApi.dll",
            "args": [],
            "cwd": "${workspaceFolder}/PaymentApi",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/swagger"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "Catalog API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-catalog",
            "program": "${workspaceFolder}/CatalogApi/bin/Debug/net8.0/CatalogApi.dll",
            "args": [],
            "cwd": "${workspaceFolder}/CatalogApi",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/swagger"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "Basket API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-basket",
            "program": "${workspaceFolder}/BasketApi/bin/Debug/net8.0/BasketApi.dll",
            "args": [],
            "cwd": "${workspaceFolder}/BasketApi",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/swagger"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        }
    ],
    "compounds": [
        {
            "name": "All Microservices",
            "configurations": [
                "Order API",
                "Payment API",
                "Catalog API",
                "Basket API"
            ]
        }
    ]
}
